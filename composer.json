{
    "name": "nadir-systems/psalm-sast-demo",
    "description": "Demo: applying Psalm taint analysis (SAST) to a vulnerable PHP application",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "vimeo/psalm": "^5.26"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "sast": "psalm --taint-analysis --no-cache"
    }
}
